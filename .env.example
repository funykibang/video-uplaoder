# ── Existing keys ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
ANTHROPIC_API_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Comma-separated 24-h times in the server's local timezone
SCHEDULE_TIMES=10:00,12:00,19:00
# Time to wipe output/ and free disk space (must be after the last run)
CLEANUP_TIME=23:30

# ── YouTube Shorts ────────────────────────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Run:  python -m pipeline.uploader.youtube --auth
#    and paste the printed refresh token below.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Instagram Reels ───────────────────────────────────────────────────────────
# Your Instagram account username and password.
# A session file (instagram_session.json) is cached after the first login.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── TikTok ────────────────────────────────────────────────────────────────────
# 1. Create an app at https://developers.tiktok.com/
# 2. Enable "Content Posting API"
# 3. Complete the OAuth2 flow to get an initial access + refresh token pair.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
