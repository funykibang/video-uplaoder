# ── AI / Script generation ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Text-to-speech (ElevenLabs) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Stock media (Pexels) ──────────────────────────────────────────────────────
PEXELS_API_KEY=

# ── Social media uploader (upload-post) ───────────────────────────────────────
# Get your API key at https://upload-post.com
UPLOAD_POST_API_KEY=
# The profile user you created in the Managed Users page
UPLOAD_POST_USER=

# ── Background video ──────────────────────────────────────────────────────────
# Local path to a background MP4. Leave empty on Railway — it will
# automatically download one from Pexels each run.
BACKGROUND_VIDEO=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Comma-separated 24-h times in the server's local timezone.
# One per day to start; expand later (e.g. 10:00,14:00,20:00).
SCHEDULE_TIMES=12:00,20:00
CLEANUP_TIME=23:30
